{
  "name": "huashu-doubao-search",
  "version": "0.2.0",
  "description": "MCP server for Doubao Search (豆包搜索) — web search built for AI agents, with ByteDance-exclusive sources (Toutiao, Douyin Baike) and an optional AI layer (context budget compression, multi-source cross-check)",
  "type": "module",
  "bin": {
    "huashu-doubao-search": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "search",
    "doubao",
    "volcengine",
    "web-search",
    "claude-code"
  ],
  "author": "alchaincyf",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alchaincyf/huashu-doubao-search.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}
